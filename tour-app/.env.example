# Leave both unset to run entirely on the static tour data in src/data/tours.js

# Endpoint that returns a JSON array of tour objects (same shape as src/data/tours.js).
# e.g. an API Gateway route backed by a Lambda that reads your tours/packages table.
VITE_TOURS_API_URL=

# Endpoint that accepts POSTed enquiry submissions.
# e.g. the API Gateway invoke URL in front of your "writer" Lambda.
VITE_ENQUIRY_API_URL=
